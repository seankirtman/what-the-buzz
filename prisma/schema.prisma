generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Dahlia {
  id                    Int      @id @default(autoincrement())
  name                  String
  slug                  String   @unique
  description           String
  detailedDescription   String
  price                 Float
  images                String
  category              String
  color                 String
  size                  String
  availableForShipping  Boolean  @default(true)
  availableForPickup    Boolean  @default(true)
  inStock               Boolean  @default(true)
  totalQty              Int      @default(0)
  qtySold               Int      @default(0)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model OrderInquiry {
  id              Int      @id @default(autoincrement())
  name            String
  email           String
  deliveryMethod  String
  pickupTime      String?
  phone           String?
  shippingAddress String?
  message         String?
  cartItems       String
  createdAt       DateTime @default(now())
}
