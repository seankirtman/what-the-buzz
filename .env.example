# Database: SQLite for local, PostgreSQL for Vercel
# Local: DATABASE_URL="file:./prisma/dev.db"
# Vercel: DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
# Get a free PostgreSQL at https://neon.tech or https://vercel.com/storage/postgres
DATABASE_URL="file:./prisma/dev.db"

# Admin panel password
ADMIN_PASSWORD="your-secure-password"

# Optional: Contact form email (Resend)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# DORRIE_EMAIL=

# Optional: Cloudinary for image uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
